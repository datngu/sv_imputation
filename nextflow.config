profiles {
  saga {
    executor.name          = 'slurm'
    executor.account       = 'nn9114k'
    process.clusterOptions = '--time=72:00:00'  
  }

  orion {
    executor.name          = 'slurm'
    process.clusterOptions = '--time=72:00:00'  
  }
  
  // ADD your hpc setup  bellow
  your_hpc {
    executor.name          = 'slurm'
    executor.account       = 'your_account'
    process.clusterOptions = '--time=72:00:00'  
    // executor.perCpuMemAllocation = true   
    // enable only if your Slurm needs --mem-per-cpu
  }

  tsd {
    executor.name          = 'slurm'
    executor.account       = 'p33_norment'
    process.clusterOptions = '--time=72:00:00'
  }

  singularity {
    singularity.enabled     = true
    singularity.autoMounts  = true
    singularity.pullTimeout = '5h'

    conda.enabled           = false
    docker.enabled          = false
    podman.enabled          = false
    shifter.enabled         = false
    charliecloud.enabled    = false
    apptainer.enabled       = false
  }

  apptainer {
    apptainer.enabled       = true
    apptainer.autoMounts    = true
    apptainer.pullTimeout   = '5h'

    conda.enabled           = false
    docker.enabled          = false
    podman.enabled          = false
    shifter.enabled         = false
    charliecloud.enabled    = false
    singularity.enabled     = false
  }

  docker {
    docker.enabled          = true
    docker.runOptions       = '-u $(id -u):$(id -g)'
    singularity.enabled     = false
    conda.enabled           = false
    podman.enabled          = false
    shifter.enabled         = false
    charliecloud.enabled    = false
    apptainer.enabled       = false
  }

  // Container image profile — combine with an engine profile:
  //   -profile docker,sv_impute
  //   -profile singularity,sv_impute
  //   -profile apptainer,sv_impute
  sv_impute {
    process.container = 'ndatth/sv-imputation:latest'
  }

}